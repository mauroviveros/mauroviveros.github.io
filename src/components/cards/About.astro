---
import type { HTMLAttributes } from 'astro/types';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';

import { Avatar, Badge, Card } from '@/components/ui';

export interface Props extends HTMLAttributes<'section'> {}

const { class: className } = Astro.props;
const [about] = await getCollection('about');

if (!about) return null;
const { Content } = await render(about);
---

<Card class:list={[className]}>
  <div class="flex items-center gap-4">
    <Avatar name={about.data.full_name} class="size-16">
      <Image
        src="/avatar.png"
        alt={about.data.full_name || 'Avatar'}
        width={64}
        height={64}
        loading="eager"
        fetchpriority="high"
      />
    </Avatar>
    <hgroup>
      <h2 class="text-xl font-bold">About me</h2>
      <div class="text-muted flex items-center gap-2 text-sm">
        <Icon name="lucide:map-pin" aria-hidden="true" />
        <span>{about.data.country}</span>
      </div>
    </hgroup>
  </div>

  <article class="flex-1 text-sm leading-relaxed text-balance">
    <Content />
  </article>

  <div class="flex flex-wrap gap-1">
    {about.data.technologies?.map((tech) => <Badge>{tech}</Badge>)}
  </div>
</Card>
