---
import type { HTMLAttributes } from 'astro/types';
import { Icon } from 'astro-icon/components';

import { Card } from '@/components/ui';
import { ACTIONS } from '@/constants';
import { getRepos } from '@/lib/github';

import Badge from '../ui/Badge.astro';
export interface Props extends HTMLAttributes<'section'> {}

const { class: className } = Astro.props;
const REPOS = await getRepos();
---

<Card class:list={[className]}>
  <h2 class="font-semibold">Projects</h2>

  <ul class="space-y-2 overflow-y-scroll pr-3 pl-1">
    {
      REPOS.map(({ name, full_name, description, topics, urls }) => {
        const actions = Object.entries(ACTIONS).filter(([key]) => !!urls[key]);

        return (
          <li class="not-last:border-border/10 relative flex flex-wrap items-center gap-2 not-last:border-b not-last:pb-2">
            <div class="flex max-w-3/4 flex-col gap-1">
              <h4 class="font-semibold">
                {urls.pkg_url ? `@${full_name}` : name}
              </h4>

              <p class="text-muted text-sm">{description}</p>

              {!!topics.length && (
                <div class="flex flex-wrap gap-1">
                  {topics.map((topic) => (
                    <Badge>{topic}</Badge>
                  ))}
                </div>
              )}
            </div>

            {!!actions.length && (
              <div class="ml-auto inline-flex gap-1">
                {actions.map(([key, { icon, title }]) => (
                  <a
                    href={urls[key]}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={title}
                    aria-label={`${title} - ${name}`}
                    class:list={[
                      'bg-background text-foreground border text-sm font-medium',
                      'inline-flex items-center justify-center',
                      'hover:bg-primary/20 transition-colors',
                      'size-8 rounded-full',
                    ]}
                  >
                    <Icon name={icon} />
                  </a>
                ))}
              </div>
            )}
          </li>
        );
      })
    }
  </ul>
</Card>
